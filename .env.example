# Default to KIS virtual trading until the paper flow is verified.
# Set APP_PASSWORD on a public server so the dashboard and broker endpoints are not exposed.
APP_USER=alphastock
APP_PASSWORD=

KIS_TRADING_MODE=paper
KIS_APP_KEY_PAPER=
KIS_APP_SECRET_PAPER=
KIS_APP_KEY_LIVE=
KIS_APP_SECRET_LIVE=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT=01
KIS_OVERSEAS_EXCHANGE=NASD
KIS_OVERSEAS_CURRENCY=USD

# Keep actual broker order transmission locked by default.
KIS_ORDER_EXECUTION=disabled
KIS_ALLOW_LIVE_ORDERS=false
KIS_HASH_ORDERS=true
